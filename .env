# Server Configuration
PORT=4000
NODE_ENV=development
JWT_SECRET=my-super-secret-jwt-key-change-this
CLIENT_URL=http://localhost:19006

# Database - SQLite
DB_TYPE=sqlite
DATABASE_URL=sqlite:./database.sqlite

# Crypto - Optional (mock mode will be used if not set)
# ETH_RPC_URL=https://mainnet.infura.io/v3/your-key
# HOT_WALLET_PRIVATE_KEY=your-private-key-here
# MASTER_MNEMONIC=your-master-mnemonic-here
# BTC_MASTER_XPUB=your-btc-xpub-here
# BTC_HOT_WALLET_ADDRESS=your-btc-address-here
# BLOCKCYPHER_TOKEN=your-blockcypher-token

# App Deep Link
APP_DEEP_LINK=ludoapp://