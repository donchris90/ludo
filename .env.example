# Server
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:3000
APP_DEEP_LINK=ludoapp://

# Database
DATABASE_URL=postgresql://ludo:password@localhost:5432/ludodb

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Paystack (Nigeria)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# Crypto - Ethereum (USDT/USDC)
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
MASTER_MNEMONIC=your twelve word mnemonic phrase here keep very secret
HOT_WALLET_PRIVATE_KEY=0xYOUR_HOT_WALLET_PRIVATE_KEY

# Crypto - Bitcoin
BTC_MASTER_XPUB=xpub...
BTC_HOT_WALLET_ADDRESS=bc1q...
BLOCKCYPHER_TOKEN=your_blockcypher_token

# Push Notifications (Firebase)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# WhatsApp Referral
WHATSAPP_SHARE_URL=https://wa.me/?text=
